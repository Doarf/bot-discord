# Token du bot (Portail développeur Discord > Bot > Reset Token)
DISCORD_TOKEN=votre_token_ici

# ID de l'application (Portail développeur > General Information > Application ID)
CLIENT_ID=votre_application_id

# Optionnel : ID de votre serveur de test (clic droit sur le serveur > Copier l'identifiant)
# Si renseigné, les commandes slash sont déployées instantanément sur ce serveur uniquement.
# Si vide, déploiement global (peut prendre jusqu'à 1h pour apparaître).
GUILD_ID=
